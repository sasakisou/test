package com.internousdev.login_practice.action;
import java.sql.SQLException;

import com.internousdev.login_practice.dao.Login_practice_DAO;
import com.internousdev.login_practice.dto.Login_practice_DTO;
import com.opensymphony.xwork2.ActionSupport;

public class login_practice_Action extends ActionSupport {
	private String name;
	private String password;
	public String execute() throws SQLException{
		String ret=ERROR;
		Login_practice_DAO dao=new Login_practice_DAO();
		Login_practice_DTO dto=new Login_practice_DTO();

		dto=dao.select(name, password);
		if(name.equals(dto.getName())){
			if(password.equals(dto.getPassword())){
				ret=SUCCESS;
			}
		}
		return ret;
	}
	public String getName(){
		return name;
	}
	public void setName(String name){
		this.name=name;
	}
	public String getPassword(){
		return password;
	}
	public void setPassword(String password){
		this.password=password;
	}

}
